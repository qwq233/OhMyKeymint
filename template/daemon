#!/system/bin/sh

MODDIR=${0%/*}
STATE_DIR=/data/adb/omk
RESTART_FILE=$STATE_DIR/restart.keymint
RESTART_ALL_FILE=$STATE_DIR/restart.all
SELF_ACK_FILE=$STATE_DIR/restart.all.keymint
PEER_ACK_FILE=$STATE_DIR/restart.all.injector

export LD_LIBRARY_PATH="$LD_LIBRARY_PATH:/vendor/lib64/:/system/lib64/:/apex/com.android.runtime/lib64/bionic/"

find_module_keymint() {
  if [ -f "/data/adb/omk/keymint" ]; then
    echo /data/adb/omk/keymint
    return 0
  fi
  if [ -f "$MODDIR/keymint" ]; then
    echo "$MODDIR/keymint"
    return 0
  fi
  if [ -f "$MODDIR/libs/arm64-v8a/keymint" ]; then
    echo "$MODDIR/libs/arm64-v8a/keymint"
    return 0
  fi
  if [ -f "$MODDIR/libs/x86_64/keymint" ]; then
    echo "$MODDIR/libs/x86_64/keymint"
    return 0
  fi
  return 1
}

shared_restart_requested() {
  if [ -f "$RESTART_ALL_FILE" ]; then
    return 0
  fi
}

cleanup_shared_restart_state() {
  if shared_restart_requested; then
    if [ -f "$SELF_ACK_FILE" ] && [ -f "$PEER_ACK_FILE" ]; then
      rm -f "$RESTART_ALL_FILE" "$SELF_ACK_FILE" "$PEER_ACK_FILE"
    fi
    return
  fi

  rm -f "$SELF_ACK_FILE" "$PEER_ACK_FILE"
}

consume_restart_request() {
  cleanup_shared_restart_state

  if [ -f "$RESTART_FILE" ]; then
    rm -f "$RESTART_FILE"
    return 0
  fi

  if shared_restart_requested && [ ! -f "$SELF_ACK_FILE" ]; then
    : > "$SELF_ACK_FILE"
    return 0
  fi

  return 1
}

cd "$MODDIR" || exit 1
mkdir -p "$STATE_DIR"

while true; do
  TARGET=$(find_module_keymint)
  if [ -z "$TARGET" ]; then
    echo "[keymint-daemon] keymint binary not found"
    sleep 5
    continue
  fi

  chmod 0755 "$TARGET"

  "$TARGET" "$@" &
  child_pid=$!

  while kill -0 "$child_pid" 2>/dev/null; do
    if consume_restart_request; then
      echo "[keymint-daemon] restart requested"
      kill -TERM "$child_pid" 2>/dev/null
      sleep 2
      if kill -0 "$child_pid" 2>/dev/null; then
        kill -KILL "$child_pid" 2>/dev/null
      fi
      cleanup_shared_restart_state
      break
    fi
    sleep 2
  done

  wait "$child_pid"
  rc=$?
  echo "[keymint-daemon] keymint exited with code $rc"
  sleep 2
done
